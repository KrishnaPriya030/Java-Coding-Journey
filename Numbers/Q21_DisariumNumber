class Solution{

static void Diasarium(int n){
int temp=n;
int digits=0;
int result=0;
while(temp>0){
temp=temp/10;
digits++;
}
 temp=n;

while(temp>0){
int rem=temp%10;
result+=Math.pow(rem,digits);
temp=temp/10;
digits--;
}
if(result==n){
System.out.println("Diasarium number");
}
else{
System.out.println("Not Diasarium number");
}
}

public static void main(String []args){
Scanner sc=new Scanner(System.in);
int n=sc.nextInt();
 Diasarium(n);
}
}
